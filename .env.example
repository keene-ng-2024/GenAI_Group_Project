# Copy this file to .env and fill in your values
# Never commit .env to version control

ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Dify — each workflow has its own API key (found in Dify → Workflow → API Access)
DIFY_API_KEY_SINGLE=your_dify_single_critic_api_key_here
DIFY_API_KEY_DUAL=your_dify_dual_critic_api_key_here

# Semantic Scholar API (optional, for paper metadata)
SEMANTIC_SCHOLAR_API_KEY=your_s2_key_here
